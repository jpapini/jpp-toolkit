{
    "name": "jpp-toolkit-monorepo",
    "private": true,
    "type": "module",
    "scripts": {
        "lint": "run-s -c lint:*",
        "lint:prettier": "prettier --cache --cache-location node_modules/.cache/prettier/.prettiercache -u -c '**/*' '!**/pnpm-lock.yaml'",
        "lint:eslint": "eslint --flag v10_config_lookup_from_file --cache --cache-location node_modules/.cache/eslint/.eslintcache .",
        "format": "run-s -c format:*",
        "format:prettier": "prettier --cache --cache-location node_modules/.cache/prettier/.prettiercache -u -w '**/*' '!**/pnpm-lock.yaml'",
        "format:eslint": "eslint --flag v10_config_lookup_from_file --cache --cache-location node_modules/.cache/eslint/.eslintcache --fix .",
        "typecheck": "turbo run typecheck",
        "dev": "turbo run dev",
        "build": "turbo run build",
        "changeset:add": "changeset add",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish"
    },
    "commitlint": {
        "extends": "@jpp-toolkit/commitlint-config"
    },
    "prettier": "@jpp-toolkit/prettier-config",
    "devDependencies": {
        "@changesets/changelog-github": "0.6.0",
        "@changesets/cli": "2.31.0",
        "@commitlint/cli": "20.5.3",
        "@jpp-toolkit/commitlint-config": "workspace:*",
        "@jpp-toolkit/eslint-config": "workspace:*",
        "@jpp-toolkit/internal-build-lib": "workspace:*",
        "@jpp-toolkit/prettier-config": "workspace:*",
        "@jpp-toolkit/ts-config": "workspace:*",
        "@types/node": "24.12.2",
        "eslint": "9.39.4",
        "npm-run-all2": "8.0.4",
        "prettier": "3.8.3",
        "turbo": "2.9.9",
        "typescript": "6.0.3"
    },
    "packageManager": "pnpm@10.33.3",
    "engines": {
        "node": "24",
        "pnpm": "10"
    },
    "volta": {
        "node": "24.15.0",
        "pnpm": "10.33.3"
    }
}
